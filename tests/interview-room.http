# R17 — Rate limit: Nhấn "Send Request" 11 lần liên tiếp trong 1 phút
# (R17 dùng cùng payload R08 — copy và paste nhanh)
POST {{baseUrl}}/api/interviews/sessions/{{sessionId}}/analyze-face
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "imageBase64": "/9j/4AAQSkZJRgABAQEASABIAAD/2wBDAAgGBgcGBQgHBwcJCQgKDBQNDAsLDBkSEw8UHRofHh0aHBwgJC4nICIsIxwcKDcpLDAxNDQ0Hyc5PTgyPC4zNDL/wAALCAABAAEBAREA/8QAFAABAAAAAAAAAAAAAAAAAAAACf/EABQQAQAAAAAAAAAAAAAAAAAAAAD/2gAIAQEAAT8AKf/Z",
  "questionIndex": 0
}

# Nhấn "Send Request" phía trên 11 lần liên tiếp
# Lần 1-10: { "success": true, "emotion": null }
# Lần 11:   { "success": true, "emotion": null, "reason": "rate_limited" }

###

# R18 — PATCH với session đã completed → phải từ chối (400)
PATCH {{baseUrl}}/api/interviews/sessions/{{sessionId}}
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "questionIndex": 0,
  "questionText": "Test câu hỏi sau khi completed",
  "transcript": "Transcript test",
  "durationSeconds": 10
}

# ✅ Expected: HTTP 400, { "success": false, "error": "Phiên phỏng vấn này đã kết thúc" }
