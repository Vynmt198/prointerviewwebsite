# ============================================================
#  backend/.env.example
#  Sao chép thành `.env`, điền giá trị, khởi động lại server.
#  Deploy: set các biến này trong dashboard của host, KHÔNG commit `.env`.
# ============================================================


# ── SERVER ───────────────────────────────────────────────────────────────────

# Cổng HTTP (mặc định 5000). Nhiều PaaS (Render, Railway) gán PORT tự động.
# PORT=5000

# Bật để tối ưu log, trust proxy, và một số guard production
# NODE_ENV=production


# ── DATABASE ─────────────────────────────────────────────────────────────────

# Phương án 1 — URI đầy đủ (local dev hoặc tự quản lý MongoDB)
MONGO_URI=mongodb://127.0.0.1:27017/prointerview

# Phương án 2 — MongoDB Atlas (loadEnv.js tự build URI từ 3 biến này nếu MONGO_URI trống)
# MONGO_ATLAS_USER=
# MONGO_ATLAS_PASSWORD=
# MONGO_ATLAS_HOST=cluster0.xxxxx.mongodb.net


# ── JWT / AUTH ────────────────────────────────────────────────────────────────

# Bắt buộc — chuỗi ngẫu nhiên dài ≥32 ký tự, không chia sẻ công khai
JWT_SECRET=

# TTL của access token (mặc định 15m). Dùng ký hiệu: 15m, 1h, 7d
# JWT_ACCESS_EXPIRES_IN=15m

# Tương thích ngược — dùng nếu JWT_ACCESS_EXPIRES_IN không set
# JWT_EXPIRES_IN=7d

# Pepper bổ sung cho refresh token hash (tùy chọn, tăng bảo mật)
# REFRESH_TOKEN_PEPPER=

# Thời hạn refresh token tính bằng ngày (mặc định 30)
# REFRESH_TOKEN_DAYS=30


# ── CORS ─────────────────────────────────────────────────────────────────────

# Origin frontend được phép gọi API — cách nhau bởi dấu phẩy
# Để trống = mọi origin (chỉ dùng cho dev/test nhanh)
# CORS_ORIGIN=https://yourapp.vercel.app,https://www.yourdomain.com
CORS_ORIGIN=http://localhost:5173


# ── GOOGLE OAUTH ─────────────────────────────────────────────────────────────

# Web Client ID từ Google Cloud Console → APIs & Services → Credentials
# Phải khớp với VITE_GOOGLE_CLIENT_ID ở frontend
GOOGLE_CLIENT_ID=


# ── ADMIN ────────────────────────────────────────────────────────────────────

# Mã mời để đăng ký tài khoản role `admin` (POST /api/auth/register).
# Để trống = không cho đăng ký admin qua API.
# ADMIN_INVITE_CODE=


# ── BOOKING / PAYMENT RATES ──────────────────────────────────────────────────

# Tỷ lệ phí nền tảng / VAT (số thập phân 0–1). Mặc định trong code: 0.15 / 0.10
# BOOKING_PLATFORM_FEE_RATE=0.15
# BOOKING_VAT_RATE=0.10


# ── PAYMENTS ─────────────────────────────────────────────────────────────────

# Secret để xác thực webhook từ cổng thanh toán (header X-Payment-Secret)
# PAYMENT_WEBHOOK_SECRET=

# URL frontend dùng khi tạo payUrl redirect (POST /api/payments/initiate)
# FRONTEND_URL=https://your-frontend.example.com

# VNPay Sandbox — bỏ comment và điền khi dùng VNPay
# VNP_TMN_CODE=
# VNP_HASH_SECRET=
# VNP_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
# VNP_RETURN_URL=https://your-api.example.com/api/payments/vnpay/vnpay-return


# ── EMAIL (Reset Password / Thông báo) ───────────────────────────────────────

# SMTP config cho emailService.js — cần để tính năng quên mật khẩu hoạt động
# Dịch vụ miễn phí: Brevo (Sendinblue), Mailgun dev tier, Gmail App Password
# MAIL_HOST=smtp.example.com
# MAIL_PORT=587
# MAIL_USER=your@email.com
# MAIL_PASS=your_smtp_password
# MAIL_FROM="ProInterview" <noreply@prointerview.com>


# ── CV ANALYZER (Python FastAPI service) ─────────────────────────────────────

# URL của Python service cv_jd_matching/ (xem cv_jd_matching/.env.example)
# Dev: service chạy local tại cổng 8000 (mặc định nếu không set)
# Prod: URL deploy trên Render/Heroku/Railway
CV_ANALYZER_URL=http://localhost:8000


# ── LLM — AI Phỏng vấn + CV Analysis (OpenAI-compatible endpoint) ───────────
#
# Dùng chung cho cả backend Node (sinh câu hỏi phỏng vấn)
# và Python service cv_jd_matching/ (scoring + suggestions).
#
# ── KHUYẾN NGHỊ #1: Groq (siêu nhanh, 14400 req/ngày free) ──────────────────
# Đăng ký: console.groq.com → API Keys → Create (đăng nhập Google/GitHub)
# Model tốt: llama-3.3-70b-versatile, qwen-2.5-72b, deepseek-r1-distill-llama-70b
#
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_API_KEY=gsk_...
LLM_MODEL=llama-3.3-70b-versatile
#
# ── KHUYẾN NGHỊ #2: Google Gemini (tiếng Việt tốt, 1500 req/ngày free) ──────
# Đăng ký: aistudio.google.com → Get API key (không cần thẻ tín dụng)
#
# LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
# LLM_API_KEY=AIza...
# LLM_MODEL=gemini-2.0-flash
#
# ── KHUYẾN NGHỊ #3: OpenRouter (nhiều model free trong 1 API) ────────────────
# Đăng ký: openrouter.ai/sign-up → openrouter.ai/keys → Create key
# Model free: thêm suffix ":free" (xem đầy đủ tại openrouter.ai/models?max_price=0)
#
# LLM_BASE_URL=https://openrouter.ai/api/v1
# LLM_API_KEY=sk-or-v1-...
# LLM_MODEL=deepseek/deepseek-chat-v3-0324:free
#
# ── KHUYẾN NGHỊ #4: Ollama (local, offline, không tốn tiền) ──────────────────
# Cài: ollama.com/download → ollama pull llama3.1:8b
# Lưu ý: Python service tự detect và bỏ json_object mode khi dùng Ollama
#
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_API_KEY=ollama
# LLM_MODEL=llama3.1:8b
