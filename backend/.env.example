# Sao chép thành `.env`, điền giá trị, khởi động lại server.
# Deploy: trên host (Railway, Render, VPS) set các biến này trong dashboard, không commit `.env`.

# Bắt buộc khi chạy API
MONGO_URI=

# Cổng HTTP (mặc định 5000). Nhiều PaaS gán PORT tự động — không cần sửa.
# PORT=5000

# Production: bật để tối ưu log / trust proxy (reverse proxy)
# NODE_ENV=production

# Bắt buộc cho JWT — dùng chuỗi dài ngẫu nhiên, không chia sẻ công khai
JWT_SECRET=
# JWT_EXPIRES_IN=7d

# CORS: danh sách origin frontend (cách nhau bởi dấu phẩy). Ví dụ:
# CORS_ORIGIN=https://yourapp.vercel.app,https://www.yourdomain.com
# Để trống = mọi origin được phép (chỉ nên dev / test nhanh)

# Cùng Web client ID như VITE_GOOGLE_CLIENT_ID trên frontend (verify ID token GIS).
GOOGLE_CLIENT_ID=

# Mã mời để đăng ký tài khoản role `admin` (API /api/auth/register). Để trống = không cho đăng ký admin qua API.
ADMIN_INVITE_CODE=

# Tỷ lệ phí nền tảng / VAT khi tạo booking (số thập phân 0–1). Mặc định trong code: 0.15 / 0.10
# BOOKING_PLATFORM_FEE_RATE=0.15
# BOOKING_VAT_RATE=0.10

# Webhook thanh toán mock (Postman gửi header X-Payment-Secret cùng giá trị)
# PAYMENT_WEBHOOK_SECRET=

# URL frontend cho payUrl trong POST /api/payments/initiate
# FRONTEND_URL=https://your-frontend.example.com

# ===== VNPay (Sandbox/Production) =====
# Nếu không điền VNP_TMN_CODE + VNP_HASH_SECRET, hệ thống sẽ fallback mock payment.
#
# Sandbox:
# VNP_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
# Production:
# VNP_URL=https://pay.vnpay.vn/vpcpay.html
#
# Return URL nên trỏ về backend route:
#   GET /api/payments/vnpay/vnpay-return
# Ví dụ:
# VNP_RETURN_URL=https://api.yourdomain.com/api/payments/vnpay/vnpay-return
#
# IPN URL cấu hình trong merchant portal của VNPay:
#   GET /api/payments/vnpay/ipn
# Ví dụ:
# VNPAY_IPN_URL=https://api.yourdomain.com/api/payments/vnpay/ipn
#
# VNP_TMN_CODE=
# VNP_HASH_SECRET=
# VNP_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
# VNP_RETURN_URL=

# ===== LLM — Sinh câu hỏi phỏng vấn (OpenAI-compatible endpoint) =====
# Bắt buộc để dùng tính năng AI question generation (POST /api/interviews/generate-questions).
# Nếu không set: API trả lỗi 500; InterviewRoom tự fallback sang câu hỏi mock.
#
# ── KHUYẾN NGHỊ #1: Google Gemini (miễn phí, tiếng Việt tốt nhất) ───────────
# Đăng ký: aistudio.google.com → Get API key → Create API key (không cần thẻ)
# Free: 1500 requests/ngày, 15 req/phút — đủ cho dev + demo
#
LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
LLM_API_KEY=AIza...
LLM_MODEL=gemini-2.0-flash
#
# ── KHUYẾN NGHỊ #2: Groq (siêu nhanh, 500-1000 tokens/s) ────────────────────
# Đăng ký: console.groq.com → API Keys → Create (đăng nhập Google/GitHub)
# Free: 14400 req/ngày, 30 req/phút — OpenAI-compatible hoàn toàn
#
# LLM_BASE_URL=https://api.groq.com/openai/v1
# LLM_API_KEY=gsk_...
# LLM_MODEL=llama-3.3-70b-versatile
# Các model tốt khác: qwen-2.5-72b, deepseek-r1-distill-llama-70b, gemma2-9b-it
#
# ── KHUYẾN NGHỊ #3: OpenRouter (nhiều model free trong 1 API) ────────────────
# Đăng ký: openrouter.ai/sign-up → openrouter.ai/keys → Create key
# Model free: thêm suffix ":free", xem đầy đủ tại openrouter.ai/models?max_price=0
#
# LLM_BASE_URL=https://openrouter.ai/api/v1
# LLM_API_KEY=sk-or-v1-...
# LLM_MODEL=deepseek/deepseek-chat-v3-0324:free
# Các model free đáng thử: google/gemini-2.0-flash-exp:free, meta-llama/llama-3.3-70b-instruct:free
# Lưu ý: model :free thường log prompt — không đẩy CV thật khi test
#
# ── KHUYẾN NGHỊ #4: Ollama (local, offline, privacy tuyệt đối) ───────────────
# Cài: ollama.com/download → pull model: ollama pull llama3.1:8b
# Server tự chạy tại localhost:11434 sau khi cài
# Yêu cầu: ≥8GB RAM (model 8B), ≥16GB (model 14B)
# Lưu ý: service tự detect Ollama và bỏ JSON mode header cho tương thích
#
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_API_KEY=ollama
# LLM_MODEL=llama3.1:8b
# Các model tốt khác: qwen2.5:7b, gemma2:9b, deepseek-r1:8b
