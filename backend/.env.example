# ============================================================
#  backend/.env.example
#  Sao chép thành `.env`, điền giá trị, khởi động lại server.
#  Deploy: set các biến này trong dashboard của host, KHÔNG commit `.env`.
# ============================================================


# ── SERVER ───────────────────────────────────────────────────────────────────

# Cổng HTTP (mặc định 5000). Nhiều PaaS (Render, Railway) gán PORT tự động.
# PORT=5000

# Bật để tối ưu log, trust proxy, và một số guard production
# NODE_ENV=production

# URL công khai của API (bắt buộc cho link ảnh/video /uploads/... trả về cho FE)
# BACKEND_URL=https://prointerview-backend.onrender.com


# ── DATABASE ─────────────────────────────────────────────────────────────────

# Phương án 1 — URI đầy đủ (local dev hoặc tự quản lý MongoDB)
MONGO_URI=mongodb://127.0.0.1:27017/prointerview

# Phương án 2 — MongoDB Atlas (loadEnv.js tự build URI từ 3 biến này nếu MONGO_URI trống)
# MONGO_ATLAS_USER=
# MONGO_ATLAS_PASSWORD=
# MONGO_ATLAS_HOST=cluster0.xxxxx.mongodb.net


# ── JWT / AUTH ────────────────────────────────────────────────────────────────

# Bắt buộc — chuỗi ngẫu nhiên dài ≥32 ký tự, không chia sẻ công khai
JWT_SECRET=

# TTL access token — khuyến nghị 15m (refresh token giữ phiên dài hạn). Ký hiệu: 15m, 1h, 7d
JWT_ACCESS_EXPIRES_IN=15m

# Tương thích ngược — chỉ dùng nếu JWT_ACCESS_EXPIRES_IN không set (tránh 7d trừ khi cố ý)
# JWT_EXPIRES_IN=7d

# Bind refresh session theo UA+IP — chỉ bật khi đã trust proxy và IP ổn định
# AUTH_STRICT_SESSION_FINGERPRINT=true

# Pepper bổ sung cho refresh token hash (tùy chọn, tăng bảo mật)
# REFRESH_TOKEN_PEPPER=

# Thời hạn refresh token tính bằng ngày (mặc định 30)
# REFRESH_TOKEN_DAYS=30


# ── CORS ─────────────────────────────────────────────────────────────────────

# Origin frontend được phép gọi API — cách nhau bởi dấu phẩy
# Để trống = mọi origin (chỉ dùng cho dev/test nhanh)
# CORS_ORIGIN=https://yourapp.vercel.app,https://www.yourdomain.com
CORS_ORIGIN=http://localhost:5173


# ── GOOGLE OAUTH ─────────────────────────────────────────────────────────────

# Web Client ID từ Google Cloud Console → APIs & Services → Credentials
# Phải khớp với VITE_GOOGLE_CLIENT_ID ở frontend
GOOGLE_CLIENT_ID=


# ── GOOGLE CLOUD VISION (Behavioral Analysis) ────────────────────────────────

# API Key từ Google Cloud Console → APIs & Services → Credentials
# Bật "Cloud Vision API" trước trong GCP project.
# Dùng để phân tích cảm xúc (joy/sorrow/anger/surprise) từ 1 snapshot/câu hỏi.
# Nếu để trống: tính năng emotion analysis bị tắt (interview vẫn chạy bình thường).
# Free tier: 1,000 ảnh/tháng miễn phí; sau đó $1.50/1,000 ảnh.


# ── CLOUDINARY (File Upload CDN) ─────────────────────────────────────────────

# Lấy từ cloudinary.com → Dashboard → API Keys.
# Khi set đủ 3 biến → file upload (avatar, CV, thumbnail, video) tự động lên CDN,
# không mất khi Render restart. Khi để trống → fallback lưu local /public/uploads.
# CLOUDINARY_CLOUD_NAME=your_cloud_name
# CLOUDINARY_API_KEY=your_api_key
# CLOUDINARY_API_SECRET=your_api_secret


# ── ADMIN ────────────────────────────────────────────────────────────────────

    # Mã mời để đăng ký tài khoản role `admin` (POST /api/auth/register).
    # Để trống = không cho đăng ký admin qua API.
    # ADMIN_INVITE_CODE=


# ── BOOKING / PAYMENT RATES ──────────────────────────────────────────────────

# Tỷ lệ phí booking mặc định (mentor thường), số thập phân 0–1. Mặc định trong code: 0.30
# BOOKING_PLATFORM_FEE_RATE=0.30
# Ưu đãi Early Mentor (top N mentor đầu tiên, còn trong thời hạn), mặc định: 0.20
# BOOKING_PLATFORM_FEE_RATE_EARLY_MENTOR=0.20
# Số mentor Early tối đa, mặc định: 20
# EARLY_MENTOR_LIMIT=20
# Thời hạn Early Mentor tính từ ngày kích hoạt, đơn vị năm, mặc định: 1
# EARLY_MENTOR_DURATION_YEARS=1
# Tỷ lệ phí khóa học mặc định, số thập phân 0–1. Mặc định trong code: 0.35
# COURSE_PLATFORM_FEE_RATE=0.35
# Tỷ lệ phí khóa học cho Early Mentor. Mặc định trong code: 0.25
# COURSE_PLATFORM_FEE_RATE_EARLY_MENTOR=0.25
# VAT tách trong giá mentor (không cộng thêm lên số CK). 0 = không lưu VAT riêng. VD 0.10 ≈ 10% trong giá.
# BOOKING_VAT_RATE=0


# ── PAYMENTS ─────────────────────────────────────────────────────────────────

# Secret để xác thực webhook từ cổng thanh toán (header X-Payment-Secret)
# PAYMENT_WEBHOOK_SECRET=

# SePay (my.sepay.vn) — webhook tiền vào TPBank / VietQR, tự xác nhận đơn PI…
# Cấu hình trên SePay: POST https://<api-host>/api/payments/webhook/sepay
# Header: Authorization: Apikey <SEPAY_WEBHOOK_API_KEY>
# SEPAY_WEBHOOK_API_KEY=

# Thời hạn chờ CK SePay (booking / khóa học / gói Pro), đơn vị phút (mặc định 15)
# TRANSFER_PAYMENT_TIMEOUT_MINUTES=15

# URL frontend dùng khi tạo payUrl redirect (POST /api/payments/initiate)
# FRONTEND_URL=https://your-frontend.example.com

# VNPay Sandbox — bỏ comment và điền khi dùng VNPay
# VNP_TMN_CODE=
# VNP_HASH_SECRET=
# VNP_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
# VNP_RETURN_URL=https://your-api.example.com/api/payments/vnpay/vnpay-return


# ── EMAIL (Reset Password / Thông báo) ───────────────────────────────────────

# SMTP config cho emailService.js — cần để tính năng quên mật khẩu hoạt động
# Dịch vụ miễn phí: Brevo (Sendinblue), Mailgun dev tier, Gmail App Password
# MAIL_HOST=smtp.example.com
# MAIL_PORT=587
# MAIL_USER=your@email.com
# MAIL_PASS=your_smtp_password
# MAIL_FROM="ProInterview" <noreply@prointerview.com>


# ── CV ANALYZER (Python FastAPI service) ─────────────────────────────────────

# URL của Python service cv_jd_matching/ (xem cv_jd_matching/.env.example)
# Dev: service chạy local tại cổng 8000 (mặc định nếu không set)
# Prod: URL deploy trên Render/Heroku/Railway
CV_ANALYZER_URL=http://localhost:8000


# ── LLM — AI Phỏng vấn + CV Analysis (OpenAI-compatible endpoint) ───────────
#
# Dùng chung cho cả backend Node (sinh câu hỏi phỏng vấn)
# và Python service cv_jd_matching/ (scoring + suggestions).
#
# ── KHUYẾN NGHỊ #1: Groq (siêu nhanh, 14400 req/ngày free) ──────────────────
# Đăng ký: console.groq.com → API Keys → Create (đăng nhập Google/GitHub)
# Model tốt: llama-3.3-70b-versatile, qwen-2.5-72b, deepseek-r1-distill-llama-70b
#
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_API_KEY=gsk_...
LLM_MODEL=llama-3.3-70b-versatile
#
# ── KHUYẾN NGHỊ #2: Google Gemini (tiếng Việt tốt, 1500 req/ngày free) ──────
# Đăng ký: aistudio.google.com → Get API key (không cần thẻ tín dụng)
#
# LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
# LLM_API_KEY=AIza...
# LLM_MODEL=gemini-2.0-flash
#
# ── KHUYẾN NGHỊ #3: OpenRouter (nhiều model free trong 1 API) ────────────────
# Đăng ký: openrouter.ai/sign-up → openrouter.ai/keys → Create key
# Model free: thêm suffix ":free" (xem đầy đủ tại openrouter.ai/models?max_price=0)
#
# LLM_BASE_URL=https://openrouter.ai/api/v1
# LLM_API_KEY=sk-or-v1-...
# LLM_MODEL=deepseek/deepseek-chat-v3-0324:free
#
# ── KHUYẾN NGHỊ #4: Ollama (local, offline, không tốn tiền) ──────────────────
# Cài: ollama.com/download → ollama pull llama3.1:8b
# Lưu ý: Python service tự detect và bỏ json_object mode khi dùng Ollama
#
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_API_KEY=ollama
# LLM_MODEL=llama3.1:8b


# ── ANTHROPIC — Claude (chất lượng cao, dùng song song với LLM_* trên) ──────
#
# Khi set ANTHROPIC_API_KEY: Sinh câu hỏi dùng Sonnet 4.5, đánh giá dùng Opus 4.8.
# Override bằng LLM_PROVIDER=anthropic để ép dùng Claude thay vì OpenAI-compat.
# Đăng ký: console.anthropic.com → API Keys (cần billing).
#
# ANTHROPIC_API_KEY=sk-ant-api03-...
# ANTHROPIC_QGEN_MODEL=claude-sonnet-4-5     # Sinh câu hỏi (nhanh, rẻ hơn)
# ANTHROPIC_EVAL_MODEL=claude-opus-4-8        # Đánh giá (chính xác nhất)
# LLM_PROVIDER=anthropic                      # Force dùng Anthropic (bỏ comment để bật)


# ── LANGFUSE — LLM Observability (tracing, cost tracking) ───────────────────
#
# Khi set → tất cả LLM calls trong interview flow được trace tự động.
# Dashboard: cloud.langfuse.com → thấy latency, token count, cost, session.
# Free tier: 50K events/tháng. Đăng ký: cloud.langfuse.com
#
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_HOST=https://cloud.langfuse.com
#
# Tỷ giá quy đổi USD → VND cho cost dashboard (Phase 0). Mặc định: 25400
# USD_TO_VND_RATE=25400


# ── ASSEMBLYAI — Server-side Speech-to-Text ─────────────────────────────────
#
# Khi set → /api/ai/transcribe dùng AssemblyAI thay vì trả "dùng browser STT".
# Tiếng Việt (language_code=vi) chính xác hơn Web Speech API nhiều.
# $50 free credit khi đăng ký (≈330 giờ audio). Đăng ký: assemblyai.com
# STT_PROVIDER=browser | assemblyai  (auto-detect nếu không set)
#
# ASSEMBLYAI_API_KEY=...
# STT_PROVIDER=assemblyai


# ── ELEVENLABS — Voice Clone TTS ─────────────────────────────────────────────
#
# Khi set → /api/ai/tts trả audio mp3 với giọng clone chất lượng cao.
# Cần Creator plan ($22/tháng) để clone giọng. Free tier chỉ dùng voice library.
# TTS_PROVIDER=did | elevenlabs  (auto-detect nếu không set)
#
# ELEVENLABS_API_KEY=sk_...
# ELEVENLABS_VOICE_ID=...        # Clone voice ID hoặc voice library ID
# ELEVENLABS_MODEL_ID=eleven_flash_v2_5
# TTS_PROVIDER=elevenlabs
#
# Đơn giá ước tính cho cost dashboard (Phase 0), USD/1K ký tự. Mặc định: 0.22 (Creator plan)
# ELEVENLABS_COST_PER_1K_CHARS_USD=0.22


# ── HUME AI — Emotion Analysis ───────────────────────────────────────────────
#
# Khi set → /api/ai/emotion phân tích cảm xúc từ audio (prosody) hoặc image (face).
# Chính xác hơn Google Vision với 48+ emotions từ giọng nói.
# 10K seconds free khi đăng ký. Đăng ký: platform.hume.ai
# EMOTION_PROVIDER=none | hume | google_vision  (auto-detect nếu không set)
#
# HUME_API_KEY=...
# HUME_SECRET_KEY=...
# EMOTION_PROVIDER=hume


# ── JaaS (Jitsi as a Service) — phòng mentor/học viên trên 8x8.vc ───────────
# Đăng ký: https://jaas.8x8.vc → API Keys → Generate API key pair
# Dev (local): dùng file .pk trong backend/keys/ (đã gitignore)
# Prod (Render): KHÔNG upload file — dùng JAAS_PRIVATE_KEY hoặc JAAS_PRIVATE_KEY_BASE64
#
# Local:
# JAAS_APP_ID=vpaas-magic-cookie-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# JAAS_API_KEY_ID=vpaas-magic-cookie-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx/fe8772
# JAAS_PRIVATE_KEY_PATH=./keys/jaas-private.pk
#
# Render / production (tạo giá trị từ file .pk):
#   cd backend && node src/scripts/encodeJaasPrivateKey.js
#   → copy dòng JAAS_PRIVATE_KEY (có \\n) vào Dashboard Render
#
# JAAS_APP_ID=
# JAAS_API_KEY_ID=
# JAAS_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\\nMIIE...\\n-----END PRIVATE KEY-----
# JAAS_PRIVATE_KEY_BASE64=   # thay thế JAAS_PRIVATE_KEY nếu muốn
# JAAS_DOMAIN=8x8.vc        # mặc định; staging: stage.8x8.vc + useStaging (chưa bật FE)
# JAAS_JWT_TTL_SEC=10800    # 3h, khớp buổi mentor tối đa
#
# JaaS Console prod: TẮT "Allow meeting participants to join unauthenticated"
# BACKEND_URL phải set đúng (avatar JWT + upload URL)


# ── D-ID Express API — Avatar Lipsync Video ──────────────────────────────────
#
# Render video avatar HR full khung (720p/1080p MP4) với lipsync chính xác.
# Kết hợp: ElevenLabs TTS → Cloudinary audio URL → D-ID Express API → video URL
# Videos được cache Redis 180 ngày → tiết kiệm credits khi câu hỏi lặp lại.
# Build plan $98/tháng (300 credits ≈ 300 phút video). Đăng ký: studio.d-id.com
#
# QUAN TRỌNG: D-ID Express API khác với D-ID Streaming WebRTC (cũ).
#   Express API = async REST → trả về video URL (MP4) sau 10-30s
#   Streaming = realtime WebRTC → deprecated trong ProInterview
#
# D_ID_API_KEY=<raw key>   — Format: Basic base64(key:) tự động trong code
#
# Ảnh HR avatar dùng làm base image (portrait PNG/JPG công khai accessible):
# HR_AVATAR_IMAGE_URL=https://res.cloudinary.com/dee4bvivu/image/upload/v1778910708/AI-female_gxbcf1.png
# HR_AVATAR_MALE_URL=https://res.cloudinary.com/.../ai-male-avatar.png   (optional)
#
# Đơn giá ước tính 1 video D-ID cho cost dashboard (Phase 0), USD/video. Mặc định: 0.08
# DID_COST_PER_VIDEO_USD=0.08
#
# Đặt giá trị (vd: "v2") khi đổi pipeline render (audio format, D-ID config, avatar ảnh mới...)
# để vô hiệu hóa TOÀN BỘ cache video avatar cùng lúc. Để trống = không đổi cache key hiện có.
# AVATAR_PIPELINE_VERSION=


# ── REDIS — Video URL Cache (Upstash free tier) ───────────────────────────────
#
# Cache video URLs sau khi D-ID render (TTL 180 ngày).
# Video cùng câu hỏi + voice + avatar → return instantly, không tốn credits.
# Savings: tháng 3+ ~70% cache hit → giảm từ $98/tháng xuống $15-30/tháng D-ID.
#
# Setup Upstash (free tier 256MB):
#   1. Đăng ký: console.upstash.com
#   2. Create Redis database (region gần Render: Singapore)
#   3. Copy REST API credentials (không cần TCP/TLS)
#
# UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
# UPSTASH_REDIS_REST_TOKEN=AXXXyyy...
#
# Khi không set → fallback in-memory Map (mất sau restart, đủ cho dev/MVP).
# Ở PRODUCTION (NODE_ENV=production), 2 biến trên BẮT BUỘC — server fail-fast khi thiếu
# (process.exit ngay lúc start), và mọi lỗi Redis runtime sẽ throw thay vì fallback im lặng
# sang Map. Xem backend/src/services/cacheService.js.


# ── SENTRY — Error tracking ───────────────────────────────────────────────────
# Đăng ký: sentry.io → New Project (Node.js/Express) → copy DSN.
# SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
# SENTRY_TRACES_SAMPLE_RATE=0.1


# ── SLACK — Alert vận hành (cost spike, baseline render bất thường, error rate cao) ──
# Tạo Incoming Webhook: api.slack.com/apps → Create App → Incoming Webhooks → Add to channel.
# SLACK_ALERT_WEBHOOK_URL=https://hooks.slack.com/services/XXX/YYY/ZZZ
