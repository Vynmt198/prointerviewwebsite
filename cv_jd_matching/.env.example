# Sao chép thành `.env`, điền giá trị.
# Các biến LLM dùng chung với backend Node.js — dùng cùng key/model.
#
# Nếu không set LLM_API_KEY → service tự fallback về Ollama tại localhost:11434.

# ── Cloud LLM (khuyến nghị) ───────────────────────────────────────────────────

# Groq (siêu nhanh, 14400 req/ngày free):
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_API_KEY=gsk_...
LLM_MODEL=llama-3.3-70b-versatile

# Google Gemini (tiếng Việt tốt, 1500 req/ngày free):
# LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
# LLM_API_KEY=AIza...
# LLM_MODEL=gemini-2.0-flash

# ── Ollama local (offline, không cần key) ─────────────────────────────────────
# Cài Ollama: ollama.com/download → ollama pull mistral:7b
# (Không cần set gì cả — service tự detect khi LLM_API_KEY trống)
